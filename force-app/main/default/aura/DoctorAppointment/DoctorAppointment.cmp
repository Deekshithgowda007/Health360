    </aura:if>
    
    
    <!--Login/SignUp-->
    <aura:if isTrue="{!and(v.isShowLogin, not(v.showBookAppointment))}">
        <div class="slds-m-around_xx-large">
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <!-- modal header start -->
                    <header class="slds-modal__header headingcolor">
                        <button class="slds-button slds-button--icon-inverse slds-modal__close" onclick="{!c.hideExampleModalForLogin}">
                            <lightning:icon iconName="utility:close" size="medium" variant="brand" class="colorIcon"/>
                            <span class="slds-assistive-text">Close</span>
                        </button>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!$Label.c.User_Verification}</h2>
                    </header>
                    <!-- modal body start -->
                    <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                        <div class="c-container">
                            <aura:if isTrue="{!v.isNextModalsForLogin}">
                                <lightning:layout>
                                    <lightning:layoutitem size="8" padding="around-small">
                                        <lightning:input type="String" aura:id="inputValue" label="{!$Label.c.Enter_Your_Email_WhatsApp_Phone_Number}" required="true"></lightning:input>
                                    </lightning:layoutitem>
                                    <lightning:layoutitem size="8"><!-- skip to next row -->
                                    </lightning:layoutitem>
                                </lightning:layout>
                            </aura:if>
                            <aura:if isTrue="{!v.isNextModalForSignUp}">
                                <lightning:layout>
                                    <lightning:layoutitem size="4" padding="around-small">
                                        <lightning:input type="text" label="{!$Label.c.Enter_Your_OTP}" aura:id="confirmotp" class="verify" maxlength="6" required="true"> </lightning:input>
                                    </lightning:layoutitem>
                                    <lightning:layoutitem size="4"><!-- skip to next row -->
                                    </lightning:layoutitem>
                                </lightning:layout>
                                <br/>
                            </aura:if>
                        </div>
                    </div>
                    
                    <!-- modal footer start-->
                    <footer class="slds-modal__footer footercolor">
                        <aura:if isTrue="{!v.hideNumberButtonLogin}">
                            <button class="slds-button slds-button_neutral" onclick="{!c.hideModalBoxForLogin}">{!$Label.c.Cancel
                                }</button>
                        </aura:if>
                        <aura:if isTrue="{!v.hideOtpButtonLogin}">
                            <button class="slds-button slds-button_neutral" onclick="{!c.hideOtpModelLogin}">{!$Label.c.Cancel
                                }</button>
                        </aura:if>
                        <aura:if isTrue="{!v.showconfirmbotton}">
                            <button class="slds-button slds-button_neutral" disabled="{!v.buttondisable}"  onclick="{!c.OpenModalBoxForLogin}">{!$Label.c.confirm}</button>
                        </aura:if>
                        <aura:if isTrue="{!v.showverifybotton}">
                            <lightning:button  label="{!$Label.c.Enter_Your_OTP}" title="Verify OTP" onclick="{!c.verifyOTPForLogin}" class="slds-var-m-left_x-small"></lightning:button>
                        </aura:if>
                    </footer>
                    
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
        </div>
    </aura:if>
    <aura:if isTrue="{!and(v.guestUserForLoginOrSignUp, not(v.showBookAppointment))}">
        <center>
            <div  class="slds-size_8-of-12" >
                <lightning:card>
                    
                    <div>
                        <div class="Header_backgroundforform">
                            <center>
                                <h1>
                                    <b>
                                        {!$Label.c.You_Don_t_have_an_Account_You_Need_To_SignUp_Please_Fill_the_Following_Data_To}
                                    </b>
                                </h1>
                            </center>
                        </div>
                    </div>
                    
                    <center>
                        <div class="slds-p-around_medium">
                            <lightning:layout>
                                <lightning:layoutItem size="6" padding="around-small">
                                    <lightning:inputName aura:id="Lead"
                                                         label="{!$Label.c.Name}"
                                                         firstName="{!$Label.c.First_Name}"
                                                         lastName="{!$Label.c.Last_Name}"
                                                         salutation="{!v.newLead.Title}"
                                                         options="{!v.salutationOptions}"
                                                         required="true" pattern="[a-zA-z]*"/>
                                    <!--lightning:input aura:id="Lead" label="FirstName" type="text" pattern="[a-zA-Z]*" value="{!v.newLead.FirstName}" /-->
                                    <!--lightning:input aura:id="Lead" label="LastName" type="text" pattern="[a-zA-Z]*" value="{!v.newLead.LastName}" /-->
                                    <lightning:input aura:id="Lead" label="{!$Label.c.Email}" type="email" value="{!v.newLead.Email}" required="true"/>
                                    <lightning:input aura:id="Lead" label="{!$Label.c.Phone}" type="phone"  pattern="[0-9]*" value="{!v.newLead.Phone}" required="true" maxlength="10" minlength="10"/>
                                </lightning:layoutItem>
                                <lightning:layoutItem size="6" padding="around-small">
                                    <lightning:inputAddress  aura:id="Lead"
                                                            addressLabel="{!$Label.c.Address}"
                                                            streetLabel="{!$Label.c.Email}"
                                                            cityLabel="{!$Label.c.City}"
                                                            countryLabel="Country"
                                                            provinceLabel="State/Province"
                                                            postalCodeLabel="{!$Label.c.PostalCode}"
                                                            street="{!v.newLead.Street}"
                                                            city="{!v.newLead.City}"
                                                            country="{!v.newLead.Country}"
                                                            province="{!v.newLead.State}"
                                                            postalCode="{!v.newLead.PostalCode}"
                                                            required="true"
                                                            />
                                </lightning:layoutItem>
                            </lightning:layout>
                            <br/>
                            
                            <center>
                                <footer class="Header_backgroundforformonetwothree">
                                    
                                    <lightning:button label="{!$Label.c.Cancel
                                                             }" onclick="{!c.handleCancelFirstLead}" variant="brand-outline" />
                                    
                                    
                                    <lightning:button label="{!$Label.c.Create}" onclick="{!c.handleCreateContactForLoginOrSignUp}" variant="brand-outline" />
                                </footer>
                            </center>
                        </div>
                    </center>
                </lightning:card>
            </div>
        </center>
    </aura:if>
    <aura:if isTrue="{!v.iframepopup}">
        <aura:if isTrue="{!v.showmyspinner}">
            <div class="outerBox spinner">
                <lightning:spinner aura:id="mySpinner" variant="brand" size="medium" class='slds=hide' />
            </div>
        </aura:if>
        
        <lightning:card>
            <div class="slds-m-around_xx-large">
                <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                    <div class="slds-modal__container FlowWidthSet">
                       <header class="slds-modal__header">
                            <button class="slds-button slds-button-icon-inverse slds-modal__close" onclick="{!c.hideExampleModalForFlow}">
                                
                                <lightning:icon iconName="utility:close" size="medium" alternative-text="Close" class="colorIcon"/>
                                
                                <span class="slds-assistive-text">Close</span>
                            </button>
                        </header>
                         <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                            <div class="c-container">
                               <iframe src="https://generative-ai-patient-triage-1eba4a129000.herokuapp.com"
                                        width="{!v.width}"
                                        height="{!v.height}"
                                        />
                                
                                       
                            </div>
                        </div>
                        <!--c:contractAmendEnglish></c:contractAmendEnglish-->
                        
                        <footer class="slds-modal__footer">
                            <button class="slds-button slds-button_neutral" onclick="{!c.hideModalBoxForFlow}">{!$Label.c.Cancel
                                }</button>
                            <button class="slds-button slds-button_neutral" onclick="{!c.hideModalBoxForservey}">{!$Label.c.Next}</button>
                        </footer>
                        
                    </div>
                </section>
                <div class="slds-backdrop slds-backdrop_open"></div>
            </div>
            
        </lightning:card>
        
    </aura:if>
    
    
    <aura:if isTrue="{!v.showZoompopup}">
        <div class="slds-m-around_xx-large">
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <!-- modal header start -->
                    <header class="slds-modal__header headingcolor">
                        <button class="slds-button slds-button--icon-inverse slds-modal__close" onclick="{!c.hideExampleModalForZoom}">
                            
                            <lightning:icon iconName="utility:close" size="medium" alternative-text="Close" class="colorIcon"/>
                            
                            <span class="slds-assistive-text">Close</span>
                        </button>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!$Label.c.Please_Select_Appointment_Type}</h2>
                    </header>
                    <!-- modal body start -->
                    <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                        <div class="c-container">
                            <center>
                                <fieldset class="slds-form-element">
                                    <legend class="slds-form-element__legend slds-form-element__label"></legend>
                                    <div class="slds-form-element__control">
                                        <div class="slds-visual-picker slds-visual-picker_small">
                                            <input type="radio" text="1" id="visual-picker-93" aura:id = "nameRadioAuraId"  value="ZoomMeeting" name="example-unique-name-36"  onclick="{!c.handleRadioClick}"/>
                                            <label for="visual-picker-93">
                                                <span class="slds-visual-picker__figure slds-visual-picker__icon slds-align_absolute-center">
                                                    <span class="slds-is-selected">
                                                        <span class="slds-icon_container">
                                                            <img src="{!$Resource.ZoomMeetingIcon}"/>
                                                        </span>
                                                    </span>
                                                    <span class="slds-is-not-selected">
                                                        <span class="slds-icon_container">
                                                            <img src="{!$Resource.ZoomMeetingIcon}"/>
                                                        </span>
                                                    </span>
                                                </span>
                                                <span class="slds-visual-picker__body">
                                                    <span class="slds-text-title">{!$Label.c.Video}</span>
                                                </span>
                                            </label>
                                        </div>
                                        <div class="slds-visual-picker slds-visual-picker_small">
                                            <input type="radio" id="visual-picker-94" value="DirectHospital" name="example-unique-name-36" onclick="{!c.handleRadioClick}"/>
                                            <label for="visual-picker-94">
                                                <span class="slds-visual-picker__figure slds-visual-picker__icon slds-align_absolute-center">
                                                    <span class="slds-is-selected">
                                                        <span class="slds-icon_container">
                                                            <img src="{!$Resource.Healthcloudimg1}"/>
                                                        </span>
                                                    </span>
                                                    <span class="slds-is-not-selected">
                                                        <span class="slds-icon_container">
                                                            <img src="{!$Resource.Healthcloudimg1}" />
                                                        </span>
                                                    </span>
                                                </span>
                                                <span class="slds-visual-picker__body">
                                                    <span class="slds-text-title">{!$Label.c.Visit_Hospital}</span>
                                                </span>
                                            </label>
                                        </div>
                                    </div>
                                </fieldset>
                            </center>
                        </div>
                    </div>
                    
                    <!-- modal footer start-->
                    <footer class="slds-modal__footer footercolor footercolor">
                        <lightning:button  label="{!$Label.c.Previous}" title="Previous" onclick="{!c.PreviousActiontoFlow}" class="slds-var-m-left_x-small"></lightning:button>
                        <lightning:button  label="{!$Label.c.Next}" title="Next" onclick="{!c.NextActiontoFlow}" class="slds-var-m-left_x-small"></lightning:button>
                    </footer>
                    
                </div>
                
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
        </div>
        
        
        
    </aura:if>
</aura:component>
