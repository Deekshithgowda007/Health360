                            {!$Label.c.Doc_Near_Me_part_2}
                        </p>
                    </div>
                    </div>
                </lightning:layoutItem>
               <lightning:layoutItem   class="layoutitem">
                   <div class="headerimageandtext">
                    <p class= "title"><b> {!$Label.c.Booking_Confirmed}</b></p>
                    <div class="slds-grid slds-p-top_low imageandtext">
                        <img src="{!$Resource.BOOK_CONFIRMED_APPOINTMENT}" />
                        <p> {!$Label.c.BOOK_CONFIRMED_APPOINTMENT}<br/>
                            {!$Label.c.BOOK_CONFIRMED_APPOINTMENT_PART_1}
                            <br/>
                            {!$Label.c.BOOK_CONFIRMED_APPOINTMENT_PART_2}
                        </p>
                    </div>
                   </div>
                    
                    
                    <div class="headerimageandtext">
                    <p class= "title"><b> {!$Label.c.Title_Know_Your_Doctor}</b></p>
                    
                    <div class="slds-grid slds-p-top_low imageandtext">
                        <img src="{!$Resource.KnowYourDoctor}"/>
                        
                        <p> {!$Label.c.Know_Your_Doctor}
                            <br/>
                            {!$Label.c.Know_Your_Doctor_part_1}
                            <br/>
                            {!$Label.c.Know_Your_Doctor_part_2}
                        </p>
                    </div>
                        </div>
                </lightning:layoutItem> 
            </lightning:layout>
                    </div>

             
      </lightning:card>
    </aura:if>
    
    
    <aura:if isTrue="{!v.welcomepage}">
        <!--div class="slds-box"-->
        <div>
            <center>
                <!--div class="Header_backgroundss"-->
                <div class="removeheader">
                    <center>
                        <h1>
                            <b>
                                Available Locations
                            </b>
                        </h1>
                    </center>
                </div>
                <!--/div-->
                <br></br>
                <div class="slds-border_bottom"></div>
            </center>
            
            <br></br>
            <div class="slds-grid slds-wrap cssstyledesign">
                <aura:iteration items="{!v.filterHopspital}" var="process" >
                    <div class="Cssdesigntwo" >
                        <lightning:card class="hospitalcss" >
                            <aura:if isTrue="{!process.Account.Image_URL__c}">
                                <div class="ProcessImage slds-align_absolute-center ">
                                    <img src="{!process.Account.Image_URL__c}"></img>
                                </div>
                                <aura:set attribute="else">
                                    <div class="DummyImage slds-align_absolute-center">
                                        <img src="{!$Resource.NoimageAvailable}"/>
                                    </div>
                                </aura:set>
                            </aura:if>
                            <br></br><br></br>
                            <div class="slds-border_bottom"></div>
                            <b>&nbsp;&nbsp;Location : {!process.Account.Name}</b>
                            <br></br>
                            <b>&nbsp;&nbsp;{!$Label.c.Phone_Number} : {!process.Account.Phone}</b>
                            <br></br>
                            <b>&nbsp;&nbsp;{!$Label.c.Website} : {!process.Account.Website}</b>
                            <br></br>
                            <b>&nbsp;&nbsp;{!$Label.c.Address} : {!process.Account.BillingAddress.city},{!process.Account.BillingAddress.state},{!process.Account.BillingAddress.postalCode},<br></br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{!process.Account.BillingAddress.country}</b>
                            <br></br>
                            <br></br>
                            <div class="slds-border_bottom"></div>
                            <br></br>
                            <lightning:button aura:id="accId" value="{!process.Account.Id}" variant="brand" label="Select Location" title="Select location" onclick="{! c.getDoctrsByHospitals}" class="slds-align_absolute-center cssbutton" />
                            <lightning:spinner aura:id="mySpinner" class="slds-hide" variant="brand" size="medium"/>
                        </lightning:card>
                    </div>
                </aura:iteration>
            </div>
            
            &nbsp;
            &nbsp;
            <br></br>
            <br></br>
            <br></br>
            <center>
                <footer class="Header_backgroundfooterforhospitalsearch">
                    <center>
                        <lightning:button label="{!$Label.c.Home}" variant="brand-outline"   iconName="utility:chevronleft"  iconPosition="left" onclick="{!c.BackToWelcomePage}" class="homecss" />
                    </center>
                </footer>
            </center>
        </div>
        <!--/div-->
    </aura:if>
    <br/>
    <!-- <div aura:id="doctprsRecordPage"> -->
    <aura:if isTrue="{!v.showrecords}" >
        <aura:if isTrue="{!v.showmyspinner}">
            <div class="outerBox spinner">
                <lightning:spinner aura:id="mySpinner" variant="brand" size="medium" class='slds=hide'/>
            </div>
        </aura:if>
        <div class="slds-box " style="height:auto;width:100%;">
            <!--lightning:card-->
                <aura:if isTrue="{!v.CheckForSpecilaity}">
                    <aura:if isTrue="{!v.portalResultsTitle != 'Available Doctors'}">
                        <div class="removemsgheader">
                            <center>
                                <h1>
                                    <b>{!v.portalResultsTitle}</b>
                                </h1>
                            </center>
                        </div>
                        <aura:set attribute="else">
                            <div class="removemsgheader">
                                <center>
                                    <h1>
                                        <b>
                                            {!v.CareSpecilityforHeading}&nbsp;Doctors at&nbsp;{!v.HospitalforHeading}
                                        </b>
                                    </h1>
                                </center>
                            </div>
                        </aura:set>
                    </aura:if>
                    <aura:set attribute="else">
                        <div class="removemsgheader">
                            <center>
                                <h1>
                                    <b>
                                        Specialties at&nbsp;{!v.HospitalforHeading}
                                    </b>
                                </h1>
                            </center>
                        </div>
                    </aura:set>
                </aura:if>
            <!--/lightning:card-->
            <div class="slds-m-around--xx-medium" >
                <lightning:layout>
                    <div class= "speciality"  style="width:20%">
                        <lightning:layoutItem>
                            <lightning:verticalNavigation
                                                          selectedItem="{!v.careIds}"
                                                          onselect="{!c.handleOnSelect}">
                                <div class="slds-box specialitys">
                                        <lightning:verticalNavigationSection label="Select Specialty">
                                        <aura:iteration items="{!v.CareList}" var="getrecords" >
                                            <lightning:verticalNavigationItem label="{!getrecords.Specialty.Name}" name="{!getrecords.Specialty.Id}" />
                                        </aura:iteration>
                                    </lightning:verticalNavigationSection>
                                </div>
                            </lightning:verticalNavigation>
                            <!--aura:if isTrue="{!v.showsub}">
                                <aura:if isTrue="{!v.showSubspeciality}">
                                    <lightning:verticalNavigation
                                                                  selectedItem="{!v.subspecialityId}"
                                                                  onselect="{!c.handleOnSubSelect}">
                                        <div class="subspeciality slds-box">
                                            <lightning:verticalNavigationSection label="Select SubSpeciality">
                                                <aura:iteration items="{!v.SubCareList}" var="getSubrecords" >
                                                    <lightning:verticalNavigationItem label="{!getSubrecords.CareTaxonomy.Name}" name="{!getSubrecords.CareTaxonomy.Id}" />
                                                </aura:iteration>
                                            </lightning:verticalNavigationSection>
                                        </div>
                                    </lightning:verticalNavigation>
                                </aura:if>
                            </aura:if-->
                        </lightning:layoutItem>
                    </div>
                    <lightning:layoutItem padding="around-medium">
                        <div class="portalInlineFilters">
                            <div class="portalInlineFilter">
                                <lightning:select name="resultsLocation" label="Filter by Location" value="{!v.selectedLocationId}" onchange="{!c.handleLocationChange}">
                                    <option value="">All locations</option>
                                    <aura:iteration items="{!v.portalLocationOptions}" var="location">
                                        <option value="{!location.value}">{!location.label}</option>
                                    </aura:iteration>
                                </lightning:select>
                            </div>
                            <span class="portalInlineHint">Changing location refreshes the doctor list instantly.</span>
                        </div>
                        <aura:if isTrue="{!v.showcount}">
                            <div class="slds-box slds-size_9-of-5 availableprovider portalResultsHeader" >
                                <div class="slds-float_right availableprovider"></div>
                                <b>Available Doctors</b> : <b>{!v.countdoctor}</b>
                                <span class="portalResultsHint">Sorted by priority, rating, experience, and reviews</span>
                            </div>
                        </aura:if>
                        <div class="slds-border_left" ></div>
                        <div class="slds-p-around_medium" >
                            <div class="slds-grid slds-wrap">
                                <aura:if isTrue="{!v.providerFound}">
                                    <aura:iteration items="{!v.selectedaccId}" var="Ids" indexVar="items">
                                        
                                        <div class="slds-size_7-of-13 slds-p-left_xx-small slds-p-horizontal_x-large" style="width:100%;">
                                            
                                            <lightning:card class="doctorResultCard">
                                                <div class="healthcloudcss doctorCardShell" style="width:100%;" >
                                                    <lightning:button variant="brand" label="{!$Label.c.Book_An_Appointement}" title="Brand action" onclick="{! c.BookAppointment }" value="{!Ids.AccountId + '|' + Ids.Practitioner.Id}" class="slds-float_right BUTTONFORCSS" />
                                                    
                                                    <!-- <lightning:button variant="brand" label="Book An Appointment" title="Brand action" onclick="{! c.BookAppointment }" value="{!Ids.Practitioner.Id}" class="slds-float_right" /> -->
                                                    
                                                    <div class="slds-grid slds-wrap" >
                                                        <table>
                                                            <tr>
                                                                <td>
                                                                    <div class="imagesetups">
                                                                        <img src="{!Ids.Practitioner.Image_URL__c}"/>
                                                                    </div>
                                                                </td>
                                                                
                                                                <td>
                                                                    <div class="health doctorName" style="font-size: 25px;">
                                                                        <h1><b>{!Ids.Practitioner.Name}</b></h1></div>
                                                                    <div class="doctorMetaRow">
                                                                        <aura:if isTrue="{!Ids.Practitioner.Priority_Doctor__c}">
                                                                            <span class="doctorBadge">Priority Doctor</span>
                                                                        </aura:if>
                                                                        <span class="doctorMetric">Rating {!Ids.Practitioner.Doctor_Rating__c}</span>
                                                                        <span class="doctorMetric">{!Ids.Practitioner.Review_Count__c} reviews</span>
                                                                        <span class="doctorMetric">{!Ids.Practitioner.Years_of_Experience__c} years exp</span>
                                                                    </div>
                                                                    
                                                                     <div class="fontfamilyfordetails" style="font-size: 17px; margin-left: 6px;">
                                                                        <h1>Specialty                : &nbsp;{!Ids.Specialty.Name}</h1>
                                                                        <h1>Location                 : &nbsp;{!Ids.Account.Name}</h1>
                                                                        <h1>Appointment Type         :&nbsp;{!Ids.Practitioner.Available_Appointment_Type__c }</h1>
                                                                        <h1>Address                  : &nbsp;{!Ids.Account.BillingCity },{!Ids.Account.BillingState},</h1>
                                                                        <h1>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{!Ids.Account.BillingCountry },&nbsp;{!Ids.Account.BillingPostalCode }</h1>                                                                   
                                                                       
                                                                    </div> 
                                                                    
                                                                </td>
                                                                
                                                                <!-- <td >
    <div class="bookanappt" style="margin: bottom 30px;">

        <lightning:button variant="brand" label="{!$Label.c.Book_An_Appointement}" title="Brand action" onclick="{! c.BookAppointment }" value="{!Ids.Practitioner.Id}" class="slds-float_right" />

    </div>
</td> -->
                                                                
                                                            </tr>
                                                        </table>
                                                        
                                                        <aura:if isTrue="{!v.showDoctors}">
                                                            <div class="slds-col">
                                                                <div class="slds-grid slds-gutters">
                                                                    <div class="align">
                                                                        <!-- <div class="health" style="font-size: 25px;">
                                                                        <h1><b>{!Ids.Practitioner.Name}</b></h1></div>
                                                                    <div class="health" style="font-size: 15px;">
                                                                        <h1>Speciality                : &nbsp;{!Ids.Specialty.Name}</h1>
                                                                        <h1>Location                  : &nbsp;{!Ids.Account.Name}</h1>
                                                                        <h1>Address                   : &nbsp;{!Ids.Account.BillingCity }</h1>
                                                                        <h1>State                     :&nbsp;{!Ids.Account.BillingState }</h1>
                                                                        <h1>Zip/PostalCode            :&nbsp;{!Ids.Account.BillingPostalCode }</h1>
                                                                        <h1>Country                   :&nbsp;{!Ids.Account.BillingCountry }</h1>
                                                                        <h1>Appointment Type          :&nbsp;{!Ids.Practitioner.Available_Appointment_Type__c }</h1>
                                                                        
                                                                    </div> -->
                                                                        
                                                                        
                                                                        
                                                                        
                                                                        
                                                                        <br/>
                                                                        <!--lightning:overlayLibrary aura:id="overlayLib"/>
                                                    <div class="popover1" value="{!Ids.Practitioner.Id}" onmouseover="{!c.handleShowPopover}">Available TimeSlot.</div>
                                                    <br/-->
                                                                        <div class="profilecss doctorActionBar">
                                                                            <lightning:button variant="base" label="{!$Label.c.View_Profile}"
                                                                                              title="{!$Label.c.Click_Here_To_See_Doctor_Details}" onclick="{!c.onDetail}" value="{!Ids.AccountId + '|' + Ids.Practitioner.Id}" class="viewbutton"   />&nbsp;&nbsp;
                                                                            <lightning:button variant="base" label="{!$Label.c.Docter_Avai}"
                                                                                              title="{!$Label.c.Click_Here_To_See_Doctors_Availabilty}" onclick="{!c.handleShowPopover}" value="{!Ids.AccountId + '|' + Ids.Practitioner.Id}" class="slds-border_left doctoravailability" />
                                                                        </div>
                                                                        
                                                                        <aura:if isTrue="{!AND(v.viewdoctordetails,Ids.Practitioner.Id==v.indexVar)}" > 
                                                                            <div class="health" style="font-size: 15px;">
                                                                                
                                                                                <lightning:tabset>
                                                                                    <lightning:tab label="{!$Label.c.overview}">
                                                                                     
                                                                                            <p><lightning:formattedText value="{!Ids.Practitioner.Overview__c}" /></p>
                                                                                      
                                                                                    </lightning:tab>
                                                                                    
                                                                                    <lightning:tab label="{!$Label.c.Awards_and_Regonition}">
                                                                                       
                                                                                            <p><lightning:formattedText value="{!Ids.Practitioner.Awards_and_Regonitions__c}" /></p>
                                                                                      
                                                                                    </lightning:tab>
                                                                                    <lightning:tab label="{!$Label.c.Expertise}">
                                                                                        
                                                                                            <p><lightning:formattedText value="{!Ids.Practitioner.Area_of_Expertise__c}" /></p>
                                                                                        
                                                                                    </lightning:tab>
                                                                                </lightning:tabset>
                                                                                
                                                                            </div>
                                                                        </aura:if>
                                                                        <br/>
                                                                    </div>  
                                                                </div>
                                                            </div> 
                                                            
                                                        </aura:if> 
                                                    </div>
                                                </div>
                                            </lightning:card>
                                        </div>
                                        <br/>
                                        <p></p>
                                    </aura:iteration>
                                    <aura:set attribute="else">
                                        <aura:if isTrue="{!v.NoDoctorFound}">
                                            <div class="notfound">
                                                <img src="{!$Resource.SalesforceImage}"></img>
                                                <b><h6>....{!$Label.c.Sorry_No_Doctor_Found_In_This_Hospital}.{!$Label.c.THANK_YOU}....</h6></b>
                                            </div>
                                        </aura:if>
                                        <aura:if isTrue="{!v.SelectSpecialtyPage}">
                                            <div class="notfound">
                                                <img src="{!$Resource.SalesforceImage}"></img>
                                                <b><h6>....{!$Label.c.PLEASE_SELECT_A_SPECIALITY_TO_FETCH_A_DOCTOR}.{!$Label.c.THANK_YOU}....</h6></b>
                                                <br/>
                                                <br/>
                                                <div class="backbuttoncss">                              
                                                    <lightning:button label="Back"  title="Back to locations" iconName="utility:back" iconPosition="left" onclick="{! c.BackToHospital}" />
                                                </div>
                                            </div>
                                        </aura:if>
                                        
                                        
                                    </aura:set>
                                    <aura:if isTrue="{!v.selectSpecialty}">
                                        <div class="notfound">
                                            <b><h6>....{!$Label.c.PLEASE_SELECT_A_SPECIALITY}....</h6></b>
                                        </div>
                                    </aura:if>
                                </aura:if>
                            </div> 
                        </div>
                        
                        <aura:if isTrue="{!v.showPginationbutton}">
                            
                            <div class="pagination">
                                
                                <aura:if isTrue="{!v.showHome}">
                                    
                                    <lightning:button label="{!$Label.c.Home}"   iconName="utility:agent_home" title="{!$Label.c.click_to_go_HomePage}" onclick="{! c.home}"/>
                                </aura:if>
                                <aura:if isTrue="{!v.showHospitalss}">
                                    <lightning:button label="Back"  title="Back to locations" iconName="utility:back" iconPosition="left" onclick="{! c.BackToHospital}"/>
                                </aura:if>
                                <aura:if isTrue="{!v.showHospitalssforCare}">
                                    <lightning:button label="Back"  title="Back to locations" iconName="utility:back" iconPosition="left" onclick="{! c.showHospitalssforCare}"/>
                                    
                                </aura:if>
                                
                                <aura:if isTrue="{!v.hideprvsbtn}">
                                    
                                    <lightning:button
                                                      label="{!$Label.c.Previous}"
                                                      iconName="utility:chevronleft"
                                                      iconPosition="left"
                                                      onclick="{! c.onPrev }"
                                                      disabled="{! v.currentPageNumber == 1}"
                                                       />
                                        
                                </aura:if>         
                                
                                <span class="slds-var-p-horizontal_x-small">
                                    Page {! (v.currentPageNumber) } of {! (v.totalPages) }
                                </span>
                                
                                <lightning:button
                                                  label="{!$Label.c.Next}"
                                                  iconName="utility:chevronright"
                                                  iconPosition="right"
                                                  onclick="{! c.onNext }"
                                                  disabled="{! v.currentPageNumber == v.totalPages }"
                                                  />
                                
                                <!-- disabled="{! v.currentPageNumber == v.totalPages }" -->
                            </div>
                        </aura:if>  
                    </lightning:layoutItem>
                    
                </lightning:layout>
                <!--lightning:button label="Back" onclick="{!c.BackToWelcomePage}" iconName="utility:back" iconPosition="left"  variant="brand"></lightning:button--> 
            </div>
        </div>
    </aura:if>
