     <aura:if isTrue="{!v.showLeadForminChildComponet}">
    <c:LeadForm aura:id="leadform" careSpcId="{!v.careSpcId}" showrecords="{!v.showrecords}" showBookAppointment="{!v.showBookAppointment}"  callcomponentmessage="{!v.callcomponentmessage}"/>
</aura:if>
    <aura:if isTrue="{!v.guestUser}">
        <center>
            <div  class="slds-size_8-of-12" >
                <lightning:card>
                    
                    <div>
                        <div class="Header_backgroundforform">
                            <center>
                                <h1>
                                    <b>
                                        {!$Label.c.you_dont_have_account}
                                    </b>
                                </h1>
                            </center>
                        </div>
                    </div>
                    
                    <center>
                        <div class="slds-p-around_medium">
                            <lightning:layout>
                                <lightning:layoutItem size="6" padding="around-small">
                                    <lightning:inputName aura:id="Lead"
                                                         label="Name"
                                                         firstName="{!v.newLead.FirstName}"
                                                         lastName="{!v.newLead.LastName}"
                                                         salutation="{!v.newLead.Title}"
                                                         options="{!v.salutationOptions}"
                                                         required="true" pattern="[a-zA-z]*"/>
                                    <!--lightning:input aura:id="Lead" label="FirstName" type="text" pattern="[a-zA-Z]*" value="{!v.newLead.FirstName}" /-->
                                    <!--lightning:input aura:id="Lead" label="LastName" type="text" pattern="[a-zA-Z]*" value="{!v.newLead.LastName}" /-->
                                    <lightning:input aura:id="Lead" label="{!$Label.c.Email}" type="email" value="{!v.newLead.Email}" required="true"/>
                                    <lightning:input aura:id="Lead" label="{!$Label.c.Phone}" type="phone"  pattern="[0-9]*" value="{!v.newLead.Phone}" required="true" maxlength="10" minlength="10"/>
                                </lightning:layoutItem>
                                <lightning:layoutItem size="6" padding="around-small">
                                    <lightning:inputAddress  aura:id="Lead"
                                                            addressLabel="{!$Label.c.Address}"
                                                            streetLabel="{!$Label.c.Street}"
                                                            cityLabel="{!$Label.c.City}"
                                                            countryLabel="{!$Label.c.Country}"
                                                            provinceLabel="{!$Label.c.State}"
                                                            postalCodeLabel="{!$Label.c.PostalCode}"
                                                            street="{!v.newLead.Street}"
                                                            city="{!v.newLead.City}"
                                                            country="{!v.newLead.Country}"
                                                            province="{!v.newLead.State}"
                                                            postalCode="{!v.newLead.PostalCode}"
                                                            required="true"
                                                            />
                                </lightning:layoutItem>
                            </lightning:layout>
                            <br/>
                            
                            <center>
                                <footer class="Header_backgroundforformonethree">
                                    
                                    <lightning:button label="{!$Label.c.Cancel
                                                             }" onclick="{!c.handleCancelforSecondLeadPage}"   variant="brand-outline"/>
                                    
                                    <lightning:button label="{!$Label.c.Create}" onclick="{!c.handleCreateContact}" variant="brand-outline" />
                                    
                                </footer>
                            </center>
                            
                        </div>
                    </center>
                </lightning:card>
            </div>
        </center>
    </aura:if>
    
    
    <aura:if isTrue="{!v.FlowPopup}">
        <aura:if isTrue="{!v.showmyspinner}">
            <div class="outerBox spinner">
                <lightning:spinner aura:id="mySpinner" variant="brand" size="medium" class='slds=hide' />
            </div>
        </aura:if>
        
        <lightning:card>
            <div class="slds-m-around_xx-large">
                <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                    <div class="slds-modal__container FlowWidthSet">
                        <header class="slds-modal__header">
                            <button class="slds-button slds-button--icon-inverse slds-modal__close" onclick="{!c.hideExampleModalForFlows}">
                                
                                <lightning:icon iconName="utility:close" size="medium" alternative-text="Close" class="colorIcon"/>
                                
                                <span class="slds-assistive-text">Close</span>
                            </button>
                        </header>
                        <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                            <div class="c-container">
                                <!--lightning:button label="Back" onclick="{!c.handleOnBack}" variant="brand" class="marginbottom"/-->
                                
                                <lightning:flow aura:id="flowData"/>
                                
                                <!--iframe width="800" height="600" style="border: 1px solid" src="https://tech-kasetti-healthcloud.my.site.com/ltng/survey/runtimeApp.app?invitationId=0Ki4x0000011E0w&amp;surveyName=dental_care_survey&amp;UUID=c1a7639f-bb6a-4258-98dc-83896d54333a" /-->
                                
                            </div>
                        </div>
                        
                        <!--footer class="slds-modal__footer">
                        <button class="slds-button slds-button_neutral" onclick="{!c.hideModalBoxForFlows}">Cancel</button>
                    </footer-->
                        
                    </div>
                </section>
                <div class="slds-backdrop slds-backdrop_open"></div>
            </div>
            
        </lightning:card>
        
    </aura:if>
    
    <aura:if isTrue="{!v.careDoctors}">
        <!--div class="slds-box" -->
        <div>
            <center>
                
                    <!--div class="Header_background"-->
                    <div class="removeheader">
                        <center>
                            <h1>
                                <b>
                                    Available Locations
                                </b>
                            </h1>
                        </center>
                    </div>
                
                <!--/div-->
              
            </center>
