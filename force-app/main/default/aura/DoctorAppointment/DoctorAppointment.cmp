<aura:component description="LightningFlow" implements="lightning:isUrlAddressable,force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction"
                access="global" controller="DoctorAppointmentController">

    <aura:attribute name="showspinnerontoggeletouch" type="Boolean" default="false" />
    <aura:attribute name="setUserId" type="String"/>
    <aura:attribute name="setsplitInvatationId" type="String"/>
    <!-- Spinner component -->
    <!-- <aura:if isTrue="{!v.showspinnerontoggeletouch}">

    <lightning:spinner aura:id="mySpinnerinaura" variant="brand" size="small" />

    </aura:if> -->

    <aura:attribute name="hidePatientprofile" type="boolean" default="false"/>



    <aura:handler name="componentEvent" event="c:componentEvent" action="{!c.handleCmpEvent}" />
    <aura:if isTrue="{!v.hidePatientprofile}">
        <c:Patientprofile />
    </aura:if>


    <aura:attribute name="Showpatientprofileui" type="boolean" default="false"/>
    <aura:attribute name="callcomponentmessage" type="String" />
    <aura:attribute name="hideprvsbtn" type="boolean" default="false"/>
    <aura:attribute name="showLeadForminChildComponet" type="boolean" default="false"/>
    <aura:attribute name="LeadFormComponent" type="boolean" default="false"/>
    <aura:attribute name="careSpcId" type="String" />
    <aura:attribute name="leadIdsss" type="String" />
    <aura:attribute name="CareSpecilityforHeading" type="String" />
    <aura:attribute name="HospitalforHeading" type="String" />
    <aura:attribute name="CheckForSpecilaity" type="boolean" default="false"/>
    <aura:attribute name="doNull" type="List" />
    <aura:attribute name="completeWrap" type="Object"/>
    <aura:attribute type="Account[]" name="acctList"/>
    <aura:attribute name="CareList" type="HealthcareProviderSpecialty[]" />
    <aura:attribute name="AccId" type="String" />
    <aura:attribute name="selectedParentId" type="String" />
    <aura:attribute name="LeadId" type="String" />
    <aura:attribute name="timezonename" type="String" />
    <aura:attribute name="servId" type="String" />
    <aura:attribute name="ConId" type="String" />
    <aura:attribute name="WorkTypeGroupId" type="String" />
    <aura:attribute name="workTypeId" type="String" />
    <aura:attribute name="FacilityId" type="String" />
    <aura:attribute name="AppointmentId" type="String" />
    <aura:attribute name="FacilityName" type="String" />
    <aura:attribute name="addingbutton" type="String" />
    
    <aura:attribute name="hidepreviousbtn" type="boolean" default="false"/>
    <aura:attribute name="shownextbtn" type="boolean" default="true"/>
    <aura:attribute name="homebuttonhide" type="boolean" default="true"/>
    
    <aura:attribute name="SubCareList" type="SObject[]" />
    <aura:attribute name="EmailZoom" type="String" />
    <!--login Page-->
    <aura:attribute name="isShowModal" type="boolean" default="false"/>
    <aura:attribute name="isNextModals" type="boolean" default="false"/>
    <aura:attribute name="isNextModal" type="boolean" default="false"/>
    <aura:attribute name="buttondisable" type="boolean" default="false"/>
    <aura:attribute name="otpCode" type="String"/>
    <aura:attribute name="PatientId" type="String"/>
    <aura:attribute name="contactId" type="String"/>
    <aura:attribute name="AppointmentType" type="String"/>
    <ltng:require scripts="{!$Resource.jsOTP}" afterScriptsLoaded="{!c.afterLoad}" />
    
    <aura:attribute name="salutationOptions" type="List" 
        default="[
                    {'label': 'Mr.', 'value': 'Mr.'},
                    {'label': 'Ms.', 'value': 'Ms.'},
                    {'label': 'Mrs.', 'value': 'Mrs.'},
                    {'label': 'Dr.', 'value': 'Dr.'},
                    {'label': 'Prof.', 'value': 'Prof.'},
                ]"/>
    <aura:attribute name="newLead" type="Lead"
        default="{ 'sobjectType': 'Lead',
                    'Title': '',
                    'FirstName': '',
                    'LastName': '',
                    'Email': '',
                    'Address': '',
                    'Company': '',
                    'Phone': ''}" />
    <aura:attribute name="message" type="String" default=""/>
    <aura:handler name="init" value="{! this }" action="{! c.init }"/>
    
    <aura:attribute name="showrecords" type="Boolean" default="false" />
    <aura:attribute name="welcomepage" type="Boolean" default="false" />
    <aura:attribute name="careDoctors" type="Boolean" default="false" />
    <aura:attribute name="showDoctors" type="Boolean" default="false" />
    <aura:attribute name="showSubspeciality" type="Boolean" default="false" />
    <aura:attribute name="selectedaccId" type="String" />
    <aura:attribute name="careIds" type="String" />
    <aura:attribute name="doctorsIds" type="String" />
    <aura:attribute name="getDocId" type="String" />
    <aura:attribute name="getSelectedcontactIds" type="String" />
    <aura:attribute name="subspecialityId" type="String" />
    <aura:attribute name="AccountIds" type="String" />
    <aura:attribute name="accounts" type="Account[]"/>
    <aura:attribute name="urls" type="String" />
    <aura:attribute name="AccountPopUp" type="Boolean" default="false"/>
    <aura:attribute name="mySpinner" type="boolean" default="false"/>
    <aura:attribute name="emptyDoctor" type="boolean" default="false"/>
    <aura:attribute name="AvailableTimeSlots" type="List" />
    <aura:attribute name="territoryId" type="String" />
    <aura:attribute name="resourceId" type="String" />
    <aura:attribute name="getcontactsIds" type="String" />
    <aura:attribute name="getHospitalIds" type="String" />
    <aura:attribute name="getcontactId" type="String" />
    <aura:attribute name="fectchUser" type="boolean" default="false"/>
    <aura:attribute name="guestUser" type="boolean" default="false"/>
    <aura:attribute name="LeadList" type="Lead" 
        default="{'sobjectType':'Lead',
                    'Name':'',
                    'LastName':'',
                    'Address':'',
                    'Email':'',
                    'Phone':'',
                    'Company':''}"/>
    <aura:attribute name="LeadListToDisplay" type="Lead[]"/>
    <lightning:flow aura:id="OwnerChangeFlow" />
    <aura:attribute name="FlowPopup" type="boolean" default="false"/>
    <aura:attribute name="selectedLookUpRecord" type="sObject" default="{}"/>
    <aura:attribute name="objContact" type="contact" default="{'sobjectType':'contact'}"/>
    <aura:attribute name="viewdoctordetails" type="boolean" default="false"/>
    <aura:attribute name="indexVar" type="String" />
    <aura:attribute name="hidepreviousbutton" type="boolean" default="false"/>
    <!--Call Id-->
    <aura:attribute name="selectedRecord" type="sObject" default="{}" description="Use,for store SELECTED sObject Record"/>
    <aura:attribute name="selectedRecIds"  type="String"/>
    <aura:attribute name="myRecordId"  type="String"/>
    <aura:handler name="oSelectedRecordEventPass" event="c:DoctorDashboard" action="{!c.handleComponentEventPass}"/>
    <!--spinner-->
    <aura:handler event="aura:waiting" action="{!c.showSpinner}"/>
    <aura:handler event="aura:doneWaiting" action="{!c.hideSpinner}"/>
    <aura:attribute name="showmyspinner" type="Boolean" default="false" />
    <aura:attribute name="providerFound" type="boolean" default="false"/>
    <!--showsub-->
    <aura:attribute name="showsub" type="boolean" default="false"/>
    <aura:attribute name="showSpecialityForDoctors" type="boolean" default="false"/>
    <aura:attribute name="NoDoctorFound" type="boolean" default="false"/>
    <aura:attribute name="SelectSpecialtyPage" type="boolean" default="false"/>
    <!--pagination Doctors-->
    
    <aura:attribute name="filteredData" type="List" />
    <aura:attribute name="pageSize" type="Integer" default="2" />
    <aura:attribute name="pageSizeOptions" type="Integer[]" default="2,4,6" />
    <aura:attribute name="currentPageNumber" type="Integer" default="1" />
    <aura:attribute name="totalPages" type="Integer" default="1" />
    <aura:attribute name="showPginationbutton" type="Boolean" default="false" />
    <aura:attribute name="ismodalClicked" type="Boolean" default="false" />
    <aura:attribute name="showverifybotton" type="Boolean" default="false" />
    <aura:attribute name="showconfirmbotton" type="Boolean" default="false" />
    <aura:attribute name="isverify" type="Boolean" default="false" />
    <aura:attribute name="isconfirm" type="Boolean" default="false" />
    
    <!--pagination for PatientRecord-->
    <aura:attribute name="pageSizess" type="Integer" default="5" />
    <aura:attribute name="pageSizeOptionsss" type="Integer[]" default="2,4,6" />
    <aura:attribute name="PresentPageNumber" type="Integer" default="1" />
    <aura:attribute name="PagesTotal" type="Integer" default="1" />
    <aura:attribute name="checkValue" type="String" default="true"/>
    <aura:attribute name="getPatientRecordsInPagination" type="List" />
    
    <!--pagination hospital-->
    <aura:attribute name="filterHopspital" type="List" />
    <aura:attribute name="careHopspital" type="List" />
    <aura:attribute name="PaginateHospitals" type="List" />
    <aura:attribute name="pageSizes" type="Integer" default="2" />
    <aura:attribute name="pageSizeOptionss" type="Integer[]" default="2,4,6" />
    <aura:attribute name="currentPageNumbers" type="Integer" default="1" />
    <aura:attribute name="totalPage" type="Integer" default="1" />
    <aura:attribute name="showHospitals" type="Boolean" default="true" />
    
    <aura:attribute name="countdoctor" type="Integer" />
    <aura:attribute name="showcount" type="Boolean" default="false" />
    <aura:attribute name="MyAppointment" type="Boolean" default="false" />
    <aura:attribute name="showHome" type="Boolean" default="true" />
    <aura:attribute name="showHospitalss" type="Boolean" default="false" />
    <aura:attribute name="showHospitalssforCare" type="Boolean" default="false" />
    <aura:attribute name="TimeList" type="String"/>
    <aura:attribute name="source" type="String"/>
    <aura:attribute name="today" type="Date" default=""/>
    
    
    <!--BookAnAppointments-->
    <aura:attribute name="selectedAccountLookUpRecord" type="String" />
    <aura:attribute name="selectedPersonAccountLookUpRecord" type="String" />
    <aura:attribute name="selectedContactLookUpRecord" type="String" />
    <aura:attribute name="selectedCareSpecialtyLookUpRecord" type="String" />
    <aura:attribute name="showBookAppointment" type="Boolean" default="true" />
    <aura:attribute name="objectAPIName" type="String"  />
    <aura:attribute name="doctorsName" type="List"  />
    <!--aura:attribute name="specialitys" type="List"  /-->
    
    <!--upadatedRecentOne-->
    
    <aura:attribute name="showSurveyPage" type="boolean" default="false"/>
    <!--Avaailability of doctor-->
    <aura:attribute name="PageHeading" type="String" default="Available Time Slots" />
    <aura:attribute name="mydata" type="List"/>
    <aura:attribute name="accdata" type="List"/>
    <aura:attribute name="showPopUp" type="boolean" default="false"/>
    <aura:attribute name="selectSpecialty" type="boolean" default="false"/>
    <aura:attribute name="ServeySubjectId" type="String" />
    
    <!--MyAppointmentsButton-->
    <aura:attribute name="MyAppointments" type="boolean" default="false"/>
    <aura:attribute name="LoginButton" type="boolean" default="true"/>
    <aura:attribute name="showPeronAccountAppointment" type="boolean" default="false"/>
    <!--aura:handler name="patientInit" value="{!this }" action="{! c.patientInit }" /-->
    <aura:attribute name="allData" type="Object" />
    
    <aura:attribute name="tableData" type="List" />
    <aura:attribute name="columns" type="Object[]" />
    <aura:attribute name="getAddress" type="String" />
    <aura:attribute name="getName" type="String" />
    <aura:attribute name="Phone" type="String" />
    <aura:attribute name="Email" type="String" />
    <aura:attribute name="Gender" type="String" />
    <aura:attribute name="Maritalstatus" type="String" />
    <aura:attribute name="Birthdate" type="String" />
    
    <aura:attribute name="allergiesdropdown" type="Boolean" default="false" />
    <aura:attribute name="medicationdropdown" type="Boolean" default="false" />
    <aura:attribute name="medicalproceduredropdown" type="Boolean" default="false" />
    <aura:attribute name="immunizationdropdown" type="Boolean" default="false" />
    <aura:attribute name="careplandropdown" type="Boolean" default="false" />
    <aura:attribute name="latestencounterdropdown" type="Boolean" default="false" />
    <aura:attribute name="healthconditiondropdown" type="Boolean" default="false" />
    
    
    <aura:attribute name="serviceappointments" type="Boolean" default="false" />
    <aura:attribute name="paststatus" type="String" />
    
    <aura:attribute name="filteredDatas" type="List" />
    <aura:attribute name="AppStatus" type="String" />
    <aura:attribute name="DateTime" type="DateTime"/>
    <aura:attribute name="ButtonShow" type="boolean" default="false"/>
    <aura:attribute name="showCancelBox" type="boolean" default="false"/>
    <aura:attribute name="selectedLeads" type="List"/>
    <aura:attribute name="isShowLogin" type="boolean" default="false"/>
    <aura:attribute name="isNextModalsForLogin" type="boolean" default="false"/>
    <aura:attribute name="isNextModalForSignUp" type="boolean" default="false"/>
    <aura:attribute name="guestUserForLoginOrSignUp" type="boolean" default="false"/>
    <aura:attribute name="showNoAppointment" type="boolean" default="false"/>
    <aura:attribute name="getLeadId" type="String" />
    <aura:attribute name="showcareback" type="boolean" default="false"/>
    <!--iframe Attributes-->
    <aura:attribute name="iframeUrl" type="String" />
    <aura:attribute name="width" type="String" default="100%;"/>
    <aura:attribute name="height" type="String" default="500px;"/>
    <aura:attribute name="iframepopup" type="boolean" default="false"/>
    <aura:attribute name="RadioSelector" type="String"/>
    <aura:attribute name="showZoompopup" type="boolean" default="false"/>
    
    <aura:attribute name="hideOtpButton" type="boolean" default="false"/>
    <aura:attribute name="hideNumberButton" type="boolean" default="false"/>
    <aura:attribute name="hideOtpButtonLogin" type="boolean" default="false"/>
    <aura:attribute name="hideNumberButtonLogin" type="boolean" default="false"/>
    <!--Language Selecting Attribute-->
    <aura:attribute name="userName" type="String"/>
    <aura:attribute name="showLanguageSection" type="Boolean" default="false" />
    <aura:attribute name="defaultLanguage" type="String"/>
    <aura:attribute name="availableLanguage" type="List"/>
    <aura:attribute name="selectedLanguage" type="String"/>
    <aura:attribute name="languageSelector" type="boolean" default="true"/>
    
    <aura:attribute name="healthcondition" type="object[]"/>
    <aura:attribute name="allergy" type="List"/>
    
    <aura:attribute name="treatment" type="object[]"/>
    <aura:attribute name="treatments" type="List"/>
    
    <aura:attribute name="medication" type="object[]"/>
    <aura:attribute name="medications" type="List"/>
    
    <aura:attribute name="latestencounterss" type="object[]"/>
    <aura:attribute name="latestencounterssdata" type="List"/>
    
    <aura:attribute name="immunization" type="object[]"/>
    <aura:attribute name="immunizations" type="List"/>
    
    <aura:attribute name="medicalprocedure" type="object[]"/>
    <aura:attribute name="medicalprocedures" type="List"/>
    
    <aura:attribute name="carepans" type="object[]"/>
    <aura:attribute name="careplans" type="List"/>
    <aura:attribute name="patientdata" type="Account"/>
    <aura:attribute name="callEinsteenChild" type="Boolean" default="false" />

    <aura:method name="navigatefromlead" action="{!c.navigatedoctorpage}" access="PUBLIC"></aura:method>
    <div aura:id="appointmentpage"></div>
    <!-- <aura:method name="navigatetoDoctorsPage" action="{!c.navigatedoctorsrecordpage}" access="PUBLIC"></aura:method> -->

    <aura:handler name="RecordEventPass" event="c:LeadFormToDoctorAppointment" action="{!c.getLeadFormRecords}"/>
    <aura:attribute name="messageTemp" type="String" />
    <aura:attribute name="attachmentId" type="String" />
    <aura:attribute name="portalHospitalName" type="String" default="Apollo Hospital" />
    <aura:attribute name="portalLocationOptions" type="Object[]" default="[]" />
    <aura:attribute name="selectedLocationId" type="String" />
    <aura:attribute name="portalResultsTitle" type="String" default="Available Doctors" />
    <aura:attribute name="portalAuthenticated" type="Boolean" default="false" />
    <aura:attribute name="portalPatientLabel" type="String" default="" />
    <aura:attribute name="portalEntryIdentifier" type="String" default="" />
    <aura:attribute name="portalOtpInput" type="String" default="" />
    <aura:attribute name="portalPassword" type="String" default="" />
    <aura:attribute name="portalConfirmPassword" type="String" default="" />
    
    
    <aura:if isTrue="{!v.LeadFormComponent}">
        <c:LeadForm />
        <p>{!v.messageTemp}</p>
    </aura:if>
    
    <aura:if isTrue="{!v.callEinsteenChild}">
        <c:EinsteinSearhChildcmp/>
    
    </aura:if>
    <aura:if isTrue="{!and(v.showBookAppointment, not(v.portalAuthenticated))}">
        <div class="portalAuthShell">
            <div class="portalAuthHero">
                <p class="portalEyebrow">Apollo patient access</p>
                <h1 class="portalAuthPageTitle">{!v.portalHospitalName} Patient Login</h1>
                <p class="portalAuthPageText">Verify with your email address to continue. If your patient account does not exist, we will guide you to registration first.</p>
            </div>

            <div class="portalAuthCard">
                <aura:if isTrue="{!v.guestUserForLoginOrSignUp}">
                    <div>
                        <p class="portalAuthEyebrow">New patient registration</p>
                        <h2 class="portalAuthTitle">Create your Apollo patient account</h2>
                        <p class="portalAuthText">We could not find an existing Apollo patient profile for this email address. Please complete registration once and we will verify your email with OTP before opening the doctor portal.</p>
                    </div>
                    <div class="portalRegistrationForm slds-m-top_large">
                        <lightning:layout multipleRows="true">
                            <lightning:layoutItem size="12" mediumDeviceSize="2" largeDeviceSize="2" padding="around-small">
                                <lightning:select aura:id="Lead" label="Title" value="{!v.newLead.Title}">
                                    <aura:iteration items="{!v.salutationOptions}" var="salutationOption">
                                        <option value="{!salutationOption.value}">{!salutationOption.label}</option>
                                    </aura:iteration>
                                </lightning:select>
                            </lightning:layoutItem>
                            <lightning:layoutItem size="12" mediumDeviceSize="5" largeDeviceSize="5" padding="around-small">
                                <lightning:input aura:id="Lead" label="First Name" type="text" value="{!v.newLead.FirstName}" required="true" pattern="[a-zA-Z ]*" />
                            </lightning:layoutItem>
                            <lightning:layoutItem size="12" mediumDeviceSize="5" largeDeviceSize="5" padding="around-small">
                                <lightning:input aura:id="Lead" label="Last Name" type="text" value="{!v.newLead.LastName}" required="true" pattern="[a-zA-Z ]*" />
                            </lightning:layoutItem>
                            <lightning:layoutItem size="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
                                <lightning:input aura:id="Lead" label="Email" type="email" value="{!v.newLead.Email}" required="true"/>
                            </lightning:layoutItem>
                            <lightning:layoutItem size="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
                                <lightning:input aura:id="Lead" label="Phone" type="phone" value="{!v.newLead.Phone}" required="true" maxlength="10" minlength="10" pattern="[0-9]*"/>
                            </lightning:layoutItem>
                            <lightning:layoutItem size="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
                                <lightning:input label="Password" type="password" value="{!v.portalPassword}" required="true"/>
                            </lightning:layoutItem>
                            <lightning:layoutItem size="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
                                <lightning:input label="Confirm Password" type="password" value="{!v.portalConfirmPassword}" required="true"/>
                            </lightning:layoutItem>
                            <lightning:layoutItem size="12" mediumDeviceSize="12" largeDeviceSize="12" padding="around-small">
                                <lightning:input aura:id="Lead" label="Street" type="text" value="{!v.newLead.Street}" required="true"/>
                            </lightning:layoutItem>
                            <lightning:layoutItem size="12" mediumDeviceSize="4" largeDeviceSize="4" padding="around-small">
                                <lightning:input aura:id="Lead" label="City" type="text" value="{!v.newLead.City}" required="true" pattern="[a-zA-Z ]*"/>
                            </lightning:layoutItem>
                            <lightning:layoutItem size="12" mediumDeviceSize="4" largeDeviceSize="4" padding="around-small">
                                <lightning:input aura:id="Lead" label="State" type="text" value="{!v.newLead.State}" required="true" pattern="[a-zA-Z ]*"/>
                            </lightning:layoutItem>
                            <lightning:layoutItem size="12" mediumDeviceSize="4" largeDeviceSize="4" padding="around-small">
                                <lightning:input aura:id="Lead" label="Postal Code" type="text" value="{!v.newLead.PostalCode}" required="true" pattern="[0-9]*"/>
                            </lightning:layoutItem>
                            <lightning:layoutItem size="12" mediumDeviceSize="12" largeDeviceSize="12" padding="around-small">
                                <lightning:input aura:id="Lead" label="Country" type="text" value="{!v.newLead.Country}" required="true" pattern="[a-zA-Z ]*"/>
                            </lightning:layoutItem>
                        </lightning:layout>
                        <p class="portalPasswordNote slds-p-horizontal_small">Email OTP verification is used for patient login in this portal. The password is validated on this form now, but secure password-based sign-in needs Experience Cloud or a dedicated auth service to store credentials safely.</p>
                        <div class="portalStandaloneActions slds-m-top_medium">
                            <lightning:button label="Back" variant="neutral" onclick="{!c.handleCancelFirstLead}" />
                            <lightning:button label="Create Account" variant="brand" onclick="{!c.handleCreateContactForLoginOrSignUp}" />
                        </div>
                    </div>
                    <aura:set attribute="else">
                        <aura:if isTrue="{!v.isNextModalForSignUp}">
                            <div>
                                <p class="portalAuthEyebrow">Step 2 of 2</p>
                                <h2 class="portalAuthTitle">Enter the OTP we sent you</h2>
                                <p class="portalAuthText">Use the verification code sent to your registered email address.</p>
                            </div>
                            <lightning:input
                                type="text"
                                label="Enter OTP"
                                value="{!v.portalOtpInput}"
                                maxlength="6"
                                class="portalStandaloneInput"
                            />
                            <div class="portalStandaloneActions">
                                <lightning:button label="Back" variant="neutral" onclick="{!c.hideOtpModelLogin}" />
                                <lightning:button label="Verify OTP" variant="brand" onclick="{!c.verifyOTPForLogin}" />
                            </div>
                            <aura:set attribute="else">
                                <div>
                                    <p class="portalAuthEyebrow">Step 1 of 2</p>
                                    <h2 class="portalAuthTitle">Sign in or check your patient account</h2>
                                    <p class="portalAuthText">Enter your registered email address. Existing patients will receive an OTP. New patients will be taken to registration automatically.</p>
                                </div>
                                <lightning:input
                                    type="email"
                                    label="Email address"
                                    value="{!v.portalEntryIdentifier}"
                                    class="portalStandaloneInput"
                                />
                                <div class="portalStandaloneActions">
                                    <lightning:button label="Continue" variant="brand" onclick="{!c.OpenModalBoxForLogin}" />
                                </div>
                            </aura:set>
                        </aura:if>
                    </aura:set>
                </aura:if>
            </div>
        </div>
    </aura:if>

    <aura:if isTrue="{!and(v.showBookAppointment, v.portalAuthenticated)}">
                <!--div class="slds-float_right  btn">
                <lightning:overlayLibrary aura:id="overlayLib"/>
                <div style="display:flex;margin-right:60px;margin-top:10px;">
                    
                    <td>
                        <lightning:icon size="small" alternativeText="Show menu" iconName="utility:user" class="colorIcon" />
                    </td>
                    <td>
                        
                        <lightning:buttonMenu  onselect="{!c.handleClick}"  variant="container" class="colorIcon" tooltip="Login Here" menuAlignment="center">
                            <aura:if isTrue="{!v.MyAppointments}">
                                <lightning:menuItem value="MyProfile" label="{!$Label.c.MY_PROFILE}"/>

                                <lightning:menuItem value="Einsteinsearch" label="Einstein Search" />

                                <aura:set attribute="else">
                                    
                                    <lightning:menuItem value="Login/SignUp" label="{!$Label.c.Login_SignUp}" />
                                        
                                    <lightning:menuItem value="Einsteinsearch" label="Einstein Search" />
                                
                                    
                                    
                                </aura:set>
                            </aura:if>
                            <lightning:menuItem value="ChangeLanguage" label="{!$Label.c.Change_Language}" />
                            
                            
                        </lightning:buttonMenu>
                        
                    </td>
                    
                </div>
            </div>
            
            <aura:if isTrue="{!v.showLanguageSection}">
                
                <section role="dialog" tabindex="-1" class="slds-modal slds-fade-in-open slds-modal_large" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1">
                    <div class="slds-modal__container" style="width:35%;min-width:35%;">
                        <header class="slds-modal__header">
                            <button class="slds-button slds-button_icon slds-modal__close slds-button_icon-inverse" title="Close" onclick="{!c.CloseLanguageData}">
                                <span class="slds-assistive-text">Close</span>
                            </button>
                            <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!$Label.c.Change_Language}</h2>
                        </header>
                        
                        <div class="slds-modal__content slds-p-around_x-large" id="modal-content-id-1">
                            <div>
                                <lightning:input aura:id="DefaultLanguage" class="slds-m-bottom_small" label="{!$Label.c.default_language}" disabled="true" value="{!v.defaultLanguage}"/>
                                
                                <lightning:select name="Language" label="{!$Label.c.select_language}" aura:id="Language" value="{!v.selectedLanguage}" onchange="{!c.changeLanguage}">
                                    <option>None</option>
                                    <option>English</option>
                                    <option>中国人</option>
                                    
                                </lightning:select>
                                
                            </div>
                        </div>
                        <footer class="slds-modal__footer">
                            <button class="slds-button slds-button_neutral" onclick="{!c.CloseLanguageData}">{!$Label.c.Cancel
                                }</button>
                            <button class="slds-button slds-button_brand" onclick="{!c.UpdateLanguageData}">{!$Label.c.Submit}</button>
                        </footer>
                    </div>
                </section>
                
            </aura:if-->
          
            <div class="bookAppointment slds-align_absolute-center">
                
                <img src="{!$Resource.DoctorApp}" style="height:100%;width:100%;"/>
      
                
            </div>
           <lightning:card  class="lightning"> 
            <div class="portalShell">
            <div class="portalHero slds-p-around_large">
                <div class="slds-align_absolute-center">
                    <div class="slds-text-align_center">
                        <p class="portalEyebrow">Trusted hospital booking</p>
                        <h1 class="slds-text-heading_large portalTitle"><b>{!v.portalHospitalName} Patient Portal</b></h1>
                        <p class="portalSubtitle slds-m-top_x-small">Sign in, choose your care specialty, pick the nearest location, and book the right doctor.</p>
                    </div>
                </div>
            </div>

            <div class="portalAuthPanel slds-p-around_large">
                <div class="portalAuthState">
                    <div>
                        <p class="portalAuthEyebrow">Verified patient access</p>
                        <h2 class="portalAuthTitle">
                            Welcome back
                            <aura:if isTrue="{!v.portalPatientLabel != ''}">
                                <span>, {!v.portalPatientLabel}</span>
                            </aura:if>
                        </h2>
                        <p class="portalAuthText">Your Apollo patient access is verified. You can now compare doctors, book appointments, and continue to profile flows.</p>
                    </div>
                    <div class="portalAuthActions">
                        <lightning:button label="My Profile" variant="neutral" onclick="{!c.openPortalProfile}" class="portalAuthButton" />
                        <lightning:button label="Sign Out" variant="destructive-text" onclick="{!c.portalSignOut}" class="portalAuthButton" />
                    </div>
                </div>
            </div>

            <div class="searchPanel slds-p-around_large">
            <lightning:layout class="search portalSearchLayout">
                <lightning:layoutItem flexibility="auto" padding="horizontal-medium">
                    <div class="custom-box portalSearchField">
                        <c:LookUpFieldsParent objectAPIName="CareSpecialty" IconName="standard:unified_health_score" aura:id="selectedDoctors" selectedRecord="{!v.selectedCareSpecialtyLookUpRecord}" label="Choose Care Specialty"/>
                    </div>
                </lightning:layoutItem>
                <lightning:layoutItem  flexibility="auto" padding="horizontal-medium">
                    <div class="custom-box portalSearchField">
                        <c:LookUpFieldsParent objectAPIName="contact" IconName="custom:custom94" aura:id="selectedDoctors"  selectedRecord="{!v.selectedContactLookUpRecord}" label="Search Doctor"/>
                    </div>
                </lightning:layoutItem>
                <lightning:layoutItem  flexibility="auto" padding="horizontal-medium">
                <div class="custom-box portalSearchField">
                        <lightning:select name="location" label="Choose Location" value="{!v.selectedLocationId}" onchange="{!c.handleLocationChange}">
                            <option value="">Select location</option>
                            <aura:iteration items="{!v.portalLocationOptions}" var="location">
                                <option value="{!location.value}">{!location.label}</option>
                            </aura:iteration>
                        </lightning:select>
                    </div>
                </lightning:layoutItem>
            </lightning:layout>
            <div class="portalSearchAction slds-align_absolute-center slds-m-top_large">
                <lightning:button variant="brand" label="{!$Label.c.search}" class="portalSearchButton" iconName="utility:search" iconPosition="left" onclick="{!c.getDataForAppointment}" />
            </div>
            </div>
            &nbsp;
            &nbsp;
            &nbsp;
            &nbsp;
              
            <lightning:layout class="layout" horizontalAlign="space">
                
                 
              <lightning:layoutItem  class="layoutitem"  >
                  
                   <div class="headerimageandtext">
                <p class= "title"><b> {!$Label.c.Book_Doctor_Appointment_Online}</b></p>
                    <div class="slds-grid slds-p-top_low imageandtext">
                        <img src="{!$Resource.FirstImageBDA}" />
                        <p >    {!$Label.c.Meet_The_Doctors}
                            <br/>
                            {!$Label.c.Meet_The_Doctors_part_2}
                        </p>
                    </div>
                    </div>
                   
                    <div class="headerimageandtext">
                    <p class= "title"><b> {!$Label.c.DOCTOR_NEAR_ME}</b></p>
                    <div class="slds-grid slds-p-top_low imageandtext">
                        <img src="{!$Resource.DocNearMe}"/>
                        <p > {!$Label.c.Doc_Near_Me}
                            <br/> 
