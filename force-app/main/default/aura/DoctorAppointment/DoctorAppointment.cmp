                                        <img src="{!$Resource.NoimageAvailable}"/>
                                    </div>
                                </aura:set>
                            </aura:if>
                            <br></br><br></br>
                            <div class="slds-border_bottom"></div>
                            <b>&nbsp;&nbsp;Location : {!process.Account.Name}</b>
                            <br></br>
                            <b>&nbsp;&nbsp;{!$Label.c.Phone_Number} : {!process.Account.Phone}</b>
                            <br></br>
                            <b>&nbsp;&nbsp;{!$Label.c.Website} : {!process.Account.Website}</b>
                            <br></br>
                            
                            <b>&nbsp;&nbsp;{!$Label.c.Address} : {!process.Account.BillingAddress.city},{!process.Account.BillingAddress.state},{!process.Account.BillingAddress.postalCode}</b>
                            <br></br>
                            <br></br>
                          
                            <div class="slds-border_bottom"></div>
                            <br></br>
                            <lightning:button aura:id="accId" value="{!process.Account.Id}" variant="brand" label="Select Location" title="Select location" onclick="{! c.getDoctrsByCareIdAndHospitals}" class="slds-align_absolute-center" />
                            <lightning:spinner aura:id="mySpinner" class="slds-hide" variant="brand" size="medium"/>
                        </lightning:card>
                    </div>
                </aura:iteration>
                
                
                
                <aura:if isTrue="{!v.showHospitals}">
                </aura:if>
            </div>
            
            
            
            <center>
                <br></br>
                <br></br>
                <br></br>
                <br></br>
                
                
                <footer class="slds-modal__footer footercolornew">
                    
                    <div class="slds-align_absolute-center buttonleftnew "  style="height: 38px;">
                        <aura:if isTrue="{!v.homebuttonhide}">
                            <lightning:button label="{!$Label.c.Home}" variant="brand-outline" class="homebutton"  iconName="utility:chevronleft"  iconPosition="left" onclick="{!c.BackToWelcomePage}" />
                        </aura:if>
                        
                        <aura:if isTrue="{!v.hidepreviousbtn}">
                            <lightning:button
                                              class="previousbutton"
                                              label="{!$Label.c.Previous}"
                                              iconName="utility:chevronleft"
                                              variant="brand-outline"
                                              iconPosition="left"
                                              onclick="{! c.onPrevious }"
                                              disabled="{! v.currentPageNumbers == 1 }" />
                        </aura:if>
                        
                        
                        <span class="slds-var-p-horizontal_x-small currentpages">
                            Page {! (v.currentPageNumbers) } of {! (v.totalPage) }
                        </span>
                        
                        <aura:if isTrue="{!v.shownextbtn}">
                            <lightning:button
                                              
                                              class="nextbutton"
                                              label="{!$Label.c.Next}"
                                              iconName="utility:chevronright"
                                              variant="brand-outline"
                                              iconPosition="right"
                                              onclick="{!c.onNextpage}"
                                              disabled="{! v.currentPageNumbers == v.totalPage }"/>
                            
                        </aura:if>
                    </div>
                    
                    
                </footer>
            </center>
        <!--/div-->
    </div>
    </aura:if>
   
    <aura:if isTrue="{!v.isShowModal}">
        <div class="slds-m-around_xx-large">
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <!-- modal header start -->
                    <header class="slds-modal__header headingcolor">
                        <button class="slds-button slds-button--icon-inverse slds-modal__close" onclick="{!c.hideExampleModal}">
                            <lightning:icon iconName="utility:close" size="medium" variant="brand" class="colorIcon"/>
                            <span class="slds-assistive-text">Close</span>
                        </button>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!$Label.c.User_Verification}</h2>
                    </header>
                    <!-- modal body start -->
                    <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                        <div class="c-container">
                            <aura:if isTrue="{!v.isNextModals}">
                                <lightning:layout>
                                    <lightning:layoutitem size="8" padding="around-small">
                                        <lightning:input type="String" aura:id="inputValue" label="{!$Label.c.Enter_Your_Email_WhatsApp_Phone_Number}" required="true"></lightning:input>
                                    </lightning:layoutitem>
                                    <lightning:layoutitem size="8"><!-- skip to next row -->
                                    </lightning:layoutitem>
                                </lightning:layout>
                            </aura:if>
                            <aura:if isTrue="{!v.isNextModal}">
                                <lightning:layout>
                                    <lightning:layoutitem size="4" padding="around-small">
                                        <lightning:input type="text" label="{!$Label.c.Enter_Your_OTP}" aura:id="confirmotp" class="verify" maxlength="6" required="true"> </lightning:input>
                                    </lightning:layoutitem>
                                    <lightning:layoutitem size="4"><!-- skip to next row -->
                                    </lightning:layoutitem>
                                </lightning:layout>
                                <br/>
                                
                            </aura:if>
                            
                            
                        </div>
                    </div>
                    
                    <!-- modal footer start-->
                    <footer class="slds-modal__footer footercolor">
                        <aura:if isTrue="{!v.hideNumberButton}">
                            <button class="slds-button slds-button_neutral" onclick="{!c.hideModalBox}">{!$Label.c.Cancel
                                }</button>
                        </aura:if>
                        <aura:if isTrue="{!v.hideOtpButton}">
                            <button class="slds-button slds-button_neutral" onclick="{!c.hideOtpModel}">{!$Label.c.Cancel
                                }</button>
                        </aura:if>                        <aura:if isTrue="{!v.isconfirm}">
                        <button class="slds-button slds-button_neutral" disabled="{!v.buttondisable}"  onclick="{!c.OpenModalBox}">{!$Label.c.confirm}</button>
                        </aura:if>
                        <aura:if isTrue="{!v.isverify}">
                            <lightning:button label="{!$Label.c.Enter_Your_OTP}" title="Verify OTP" onclick="{!c.verifyOTP}" class="slds-var-m-left_x-small"></lightning:button>
                        </aura:if>
                    </footer>
                    
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
        </div>
    </aura:if>
    
    <aura:if isTrue="{!v.showPopUp}">
        <div class="slds-m-around_xx-large">
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <!-- modal header start -->
                    <header class="slds-modal__header">
                        <button class="slds-button slds-button--icon-inverse slds-modal__close" onclick="{!c.hideTimeModal}">
                            <lightning:icon iconName="utility:close" size="medium" variant="brand" class="colorIcon"/>
                            <span class="slds-assistive-text">Close</span>
                        </button>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!$Label.c.Available_Time_slot}</h2>
                    </header>
                    <!-- modal body start -->
                    <div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
                        <div class="c-container">
                            <table class="slds-table slds-table--bordered slds-table--striped slds-table--cell-buffer slds-table--fixed-layout">
                                <thead>
                                    <tr class="slds-text-heading--label">
                                        <th scope="col"><div class="slds-truncate" title="Vehicle Name">{!$Label.c.DayOfWeek}</div></th>
                                        <th scope="col"><div class="slds-truncate" title="Service Date">{!$Label.c.StartTime}</div></th>
                                        <th scope="col"><div class="slds-truncate" title="Service Date">{!$Label.c.EndTime}</div></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <aura:iteration items="{!v.mydata}" var="row" indexVar="index">
                                        <tr>
                                            <th scope="row"><div class="slds-truncate" >
                                                <a onclick="{!c.showPopup}" value="{!row}" data-index="{!index}">{!row.DayOfWeek}</a>
                                                </div></th>
                                            <td><div class="slds-truncate" title="{!row.Phone}">{!row.StartTime}</div></td>
                                            <td><div class="slds-truncate" title="{!row.Phone}">{!row.EndTime}</div></td>
                                        </tr>
                                    </aura:iteration>
                                    
                                </tbody>
                                <lightning:button variant="brand" label="{!$Label.c.Closebutton}" title="{!$Label.c.Closebutton}" onclick="{! c.handlClose }" class="moveclose" />
                            </table>
                        </div>
                    </div>
                    
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
        </div>
    </aura:if>
    <aura:if isTrue="{!v.ShowMyAppointment}">
        <c:DoctorAppointmentDashboard />
    </aura:if>
    
   
    
    <aura:if isTrue="{!v.showPeronAccountAppointment}">
        
        <lightning:card>
            
            <div class="Header_background" >
                
                <center>
                    <h1>
                        <b>
                            {!$Label.c.MY_PROFILE}
                            
                        </b>
                        <lightning:button label="{!$Label.c.Home}"  class="slds-float_right" iconName="utility:agent_home" title="click to go HomePage" onclick="{! c.BackToWelcomePage}"/>
                        
                        
                    </h1>
                </center>
            </div></lightning:card>
        
        
      
        
        <div class="major-grid" style="height:auto;">
            <div class="top-left slds-theme_default">
                <lightning:Card>
                    <div class="slds-box slds-theme_shade">
                        
                        
                        <div class="slds-grid slds-wrap">
                            <div class="slds-col slds-size_1-of-1 slds-large-size_4-of-12">
                                <img src="{!$Resource.maskusageimg1}" style="height:150px;"/>
                                
                            </div>
                            
                            <div class="slds-col slds-size_1-of-1 slds-large-size_4-of-12">
                                <h5><b> {!$Label.c.Name} : &nbsp;</b>
                                    
                                    {!v.patientdata.Name}</h5>
                                <br/>
                                
                                <h5> <b> {!$Label.c.Date_of_Birth} : &nbsp;</b>
                                    {!v.patientdata.PersonBirthdate}</h5>
                                <br/>
                                
                                <h5><b> {!$Label.c.Phone} : &nbsp;</b>
                                    
                                    {!v.patientdata.Phone}</h5>
                                
                                <br/>
                                <h5> <b>{!$Label.c.Email} : &nbsp;</b>
                                    {!v.patientdata.PersonEmail}</h5>
                                
                            </div>
                            <div class="slds-col slds-size_1-of-1 slds-large-size_4-of-12">
                                
                                
                                <h5><b>{!$Label.c.Gender} : &nbsp;</b>
                                    
                                    
                                    {!v.patientdata.HealthCloudGA__Gender__pc}</h5>
                                <br/>
                                <h5><b>Maritial Status : &nbsp;</b>
                                    {!v.patientdata.PersonMaritalStatus}  &nbsp;</h5>
                                  <br/>

                                <h5><b>{!$Label.c.Address} : &nbsp;</b>
                                    
                                    {!v.patientdata.PersonMailingStreet}&nbsp;,
                                    
                                    {!v.patientdata.PersonMailingCity }&nbsp;,
                                    {!v.patientdata.PersonMailingState}&nbsp;,
                                    {!v.patientdata.PersonMailingCountry }&nbsp;-
                                    {!v.patientdata.PersonMailingPostalCode}

                                </h5></div></div></div>
                </lightning:Card>
                
                <br/>
                
                <br/>
                <lightning:card>
                    <div class="slds-box slds-theme_shade">
                        
                        <b> <div class="slds-text-heading_medium">{!$Label.c.Appointments}</div></b></div>
                    
                    <lightning:tabset variant="scoped">
                        
                        
                        <lightning:tab onactive="{! c.handleSelected }" label="{!$Label.c.Upcoming}" id="select">
                            <lightning:spinner aura:id="mySpinner" class="slds-hide" variant="brand" size="medium"/>
                            
                            <aura:if isTrue="{!v.serviceappointments}">
                                
                                <lightning:datatable
                                                     aura:id="table"
                                                     columns="{! v.columns }"
                                                     data="{!v.tableData}"
                                                     hideCheckboxColumn="false"
                                                     keyField="Id"
                                                     showRowNumberColumn="true"
                                                     onrowselection="{! c.updateSelectedText}"
                                                     onrowaction="{! c.handleAction }"/>
                                
                                <aura:set attribute="else">
                                    <center>{!$Label.c.There_are_no_Appointments_yet}.</center>
                                </aura:set>
                            </aura:if>
                        </lightning:tab>
                        
                        
                        <lightning:tab onactive="{! c.handlCompleted }" label="{!$Label.c.Past}" id="completedcancelled">
                            
                            <lightning:spinner aura:id="mySpinner" class="slds-hide" variant="brand" size="medium"/>
                            <aura:if isTrue="{!v.serviceappointments}">
                                
                                <lightning:datatable
                                                     aura:id="table"
                                                     columns="{! v.columns }"
                                                     data="{!v.tableData}"
                                                     hideCheckboxColumn="false"
                                                     keyField="Id"
                                                     showRowNumberColumn="true"
                                                     onrowselection="{! c.updateSelectedText}"
                                                     onrowaction="{! c.handleAction }"/>
                                
                                <aura:set attribute="else">
                                    <center>{!$Label.c.There_are_no_Appointments_yet}.</center>
                                </aura:set>
                            </aura:if>
                        </lightning:tab>
                        
                    </lightning:tabset>
                    
                    <br/>
                    <br/>
                    
                    
                    <div class="slds-align_absolute-center">
                       
                        <lightning:button
                                          label="{!$Label.c.Previous}"
                                          iconName="utility:chevronleft"
                                          iconPosition="left"
                                          onclick="{! c.onPreviousParent}"
                                          disabled="{! v.PresentPageNumber == 1 }" />
                        <span class="slds-var-p-horizontal_x-small">
                            {!$Label.c.Page} {! (v.PresentPageNumber) }  {!$Label.c.of} {! (v.PagesTotal) }
                        </span>
                        <lightning:button
                                          label="{!$Label.c.Next}"
                                          iconName="utility:chevronright"
                                          iconPosition="right"
                                          onclick="{! c.onNextParent }"
                                          disabled="{! v.PresentPageNumber == v.PagesTotal}" />
                        
                    </div>
                    
                </lightning:card>
            </div>
            
            
            
            
            <div class="top-right slds-theme_default">
                
                <div class="slds-box slds-theme_shade">
                    <b> <div class="slds-text-heading_medium" > <img src="{!$Resource.PatientCard}"/>
                        {!$Label.c.Patient_Card}</div></b></div>
                
                <div class="slds-box slds-theme_shade">
                    
                    
                    
                    
                    <div class="slds-section slds-is-close animate" aura:id="lunchSection">
                        <aura:if isTrue="{!v.showspinnerontoggeletouch}">

                        <lightning:spinner aura:id="mySpinnerinaura" variant="brand" size="small" />
                        </aura:if>
                        <!-- <lightning:spinner aura:id="mySpinner" variant="brand" size="medium" class='slds=hide' /> -->
                        <h3 class="slds-section__title">
                            
                            <button aria-controls="lunchItemList" class="slds-button slds-section__title-action" onclick="{!c.toggleSection}" data-auraId="lunchSection">
                                
                                <lightning:icon iconName="utility:switch"
                                                size="x-small"
                                                class="slds-section__title-action-icon slds-button__icon_left"
                                                alternativeText="button icon"
                                                />
                                
                                
                                <span class="slds-truncate" title="lunch item">{!$Label.c.Allergies}</span>
                                
                                
                            </button>
                        </h3>
                        
                        
                        <div class="slds-section__content" id="lunchItemList">
                            <aura:if isTrue="{!v.allergiesdropdown}">
                                
                                <lightning:datatable
                                                     aura:id="table"
                                                     columns="{! v.healthcondition }"
                                                     data="{!v.allergy}"
                                                     hideCheckboxColumn="true"
                                                     keyField="Id"
                                                     showRowNumberColumn="true"
                                                     onrowselection="{! c.updateSelectedText}"
                                                     onrowaction="{! c.handleAction }"/>
                                <aura:set attribute="else">
                                    <center>{!$Label.c.There_are_no_records_for_this_section}.</center>
                                </aura:set>
                            </aura:if>
                            
                            
                        </div>
                        
                        
                        
                        
                    </div>
                    
                    
                    
                    <div class="slds-section slds-is-close animate" aura:id="DinnerSection">
                        <h3 class="slds-section__title">
                            <button aria-controls="DinnerId" class="slds-button slds-section__title-action" onclick="{!c.toggleSection}" data-auraId="DinnerSection">
                                <lightning:icon iconName="utility:switch"
                                                alternativeText="button icon"
                                                size="x-small"
                                                class="slds-section__title-action-icon slds-button__icon_left"/>
                                <span class="slds-truncate" title="Dinner Item">{!$Label.c.Health_Conditions}</span>
                            </button>
                        </h3>
                        
                        <div class="slds-section__content" id="DinnerItemId">
                            <aura:if isTrue="{!v.healthconditiondropdown}">
                                <lightning:datatable
                                                     aura:id="table"
                                                     columns="{! v.treatment }"
                                                     data="{!v.treatments}"
                                                     hideCheckboxColumn="true"
                                                     keyField="Id"
                                                     showRowNumberColumn="true"
                                                     onrowselection="{! c.updateSelectedText}"
                                                     onrowaction="{! c.handleAction }"/>
                                <aura:set attribute="else">
                                    <center>{!$Label.c.There_are_no_records_for_this_section}.</center>
                                </aura:set>
                            </aura:if>
                        </div>
                        
                    </div>
                    <div class="slds-section slds-is-close animate" aura:id="medicationSection">
                        <h3 class="slds-section__title">
                            <button aria-controls="medicationId" class="slds-button slds-section__title-action" onclick="{!c.toggleSection}" data-auraId="medicationSection">
                                <lightning:icon iconName="utility:switch"
                                                alternativeText="button icon"
                                                size="x-small"
                                                class="slds-section__title-action-icon slds-button__icon_left"/>
                                <span class="slds-truncate" title="Dinner Item">{!$Label.c.Medications}</span>
                            </button>
                        </h3>
                        
                        <div class="slds-section__content" id="medicationItemId">
                            <aura:if isTrue="{!v.medicationdropdown}">
                                <lightning:datatable
                                                     aura:id="table"
                                                     columns="{! v.medication }"
                                                     data="{!v.medications}"
                                                     hideCheckboxColumn="true"
                                                     keyField="Id"
                                                     showRowNumberColumn="true"
                                                     onrowselection="{! c.updateSelectedText}"
                                                     onrowaction="{! c.handleAction }"/>
                                <aura:set attribute="else">
                                    <center>{!$Label.c.There_are_no_records_for_this_section}.</center>
                                </aura:set>
                            </aura:if>
                            
                        </div>
                        
                    </div>
                    <div class="slds-section slds-is-close animate" aura:id="latestencountersSection">
                        <!--section header-->
                        <h3 class="slds-section__title">
                            <button aria-controls="latestencountersSectionId" class="slds-button slds-section__title-action" onclick="{!c.toggleSection}" data-auraId="latestencountersSection">
                                <lightning:icon iconName="utility:switch"
                                                alternativeText="button icon"
                                                size="x-small"
                                                class="slds-section__title-action-icon slds-button__icon_left"/>
                                <span class="slds-truncate" title="Dinner Item">{!$Label.c.Latest_Encounters}</span>
                            </button>
                        </h3>
                        <!--section body-->
                        
                        <div class="slds-section__content" id="latestencountersSectionItemId">
                            <aura:if isTrue="{!v.latestencounterdropdown}">
                                <lightning:datatable
                                                     aura:id="table"
                                                     columns="{! v.latestencounterss}"
                                                     data="{!v.latestencounterssdata}"
                                                     hideCheckboxColumn="true"
                                                     keyField="Id"
                                                     showRowNumberColumn="true"
                                                     onrowselection="{! c.updateSelectedText}"
                                                     onrowaction="{! c.handleAction }"/>
                                <aura:set attribute="else">
                                    <center>{!$Label.c.There_are_no_records_for_this_section}.</center>
                                </aura:set>
                            </aura:if>
                            
                        </div>
                        
                    </div>
                    <div class="slds-section slds-is-close animate" aura:id="Immunization">
                        <!--section header-->
                        <h3 class="slds-section__title">
                            <button aria-controls="immunizationId" class="slds-button slds-section__title-action" onclick="{!c.toggleSection}" data-auraId="Immunization">
                                <lightning:icon iconName="utility:switch"
                                                alternativeText="button icon"
                                                size="x-small"
                                                class="slds-section__title-action-icon slds-button__icon_left"/>
                                <span class="slds-truncate" title="Dinner Item">{!$Label.c.Immunization}</span>
                            </button>
                        </h3>
                        <!--section body-->
                        
                        <div class="slds-section__content" id="immunizationId">
                            <aura:if isTrue="{!v.immunizationdropdown}">
                                <lightning:datatable
                                                     aura:id="table"
                                                     columns="{! v.immunization}"
                                                     data="{!v.immunizations}"
                                                     hideCheckboxColumn="true"
                                                     keyField="Id"
                                                     showRowNumberColumn="true"
                                                     onrowselection="{! c.updateSelectedText}"
                                                     onrowaction="{! c.handleAction }"/>
                                <aura:set attribute="else">
                                    <center>{!$Label.c.There_are_no_records_for_this_section}.</center>
                                </aura:set>
                            </aura:if>
                            
                        </div>
                        
                    </div>
                    <div class="slds-section slds-is-close animate" aura:id="medicalproceduresection">
                        <!--section header-->
                        <h3 class="slds-section__title">
                            <button aria-controls="medicalproceduresectionId" class="slds-button slds-section__title-action" onclick="{!c.toggleSection}" data-auraId="medicalproceduresection">
                                <lightning:icon iconName="utility:switch"
                                                alternativeText="button icon"
                                                size="x-small"
                                                class="slds-section__title-action-icon slds-button__icon_left"/>
                                <span class="slds-truncate" title="Dinner Item">{!$Label.c.Medical_Procedure}</span>
                            </button>
                        </h3>
                        <!--section body-->
                        
                        <div class="slds-section__content" id="medicalproceduresectionItemId">
                            <aura:if isTrue="{!v.medicalproceduredropdown}">
                                <lightning:datatable
                                                     aura:id="table"
                                                     columns="{! v.medicalprocedure}"
                                                     data="{!v.medicalprocedures}"
                                                     hideCheckboxColumn="true"
                                                     keyField="Id"
                                                     showRowNumberColumn="true"
                                                     onrowselection="{! c.updateSelectedText}"
                                                     onrowaction="{! c.handleAction }"/>
                                <aura:set attribute="else">
                                    <center>{!$Label.c.There_are_no_records_for_this_section}.</center>
                                </aura:set>
                            </aura:if>
                            
                        </div>
                        
                    </div>
                    <div class="slds-section slds-is-close animate" aura:id="careplanSection">
                        <!--section header-->
                        <h3 class="slds-section__title">
                            <button aria-controls="careplanId" class="slds-button slds-section__title-action" onclick="{!c.toggleSection}" data-auraId="careplanSection">
                                <lightning:icon iconName="utility:switch"
                                                alternativeText="button icon"
                                                size="x-small"
                                                class="slds-section__title-action-icon slds-button__icon_left"/>
                                <span class="slds-truncate" title="Dinner Item">{!$Label.c.Care_Plan}</span>
                            </button>
                        </h3>
                        <!--section body-->
                        
                        <div class="slds-section__content"   id="careplanItemId">
                            <aura:if isTrue="{!v.careplandropdown}">
                                
                                <lightning:datatable
                                                     aura:id="table"
                                                     columns="{! v.carepans }"
                                                     data="{!v.careplans}"
                                                     hideCheckboxColumn="true"
                                                     keyField="Id"
                                                     showRowNumberColumn="true"
                                                     onrowselection="{! c.updateSelectedText}"
                                                     onrowaction="{! c.handleAction }"/>
                                <aura:set attribute="else">
                                    <center>{!$Label.c.There_are_no_records_for_this_section}.</center>
                                </aura:set>
                            </aura:if>
                        </div>
                        
                    </div>
                </div>
                
                
                <br/>
                <br/>
