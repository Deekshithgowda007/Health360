<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <isExposed>true</isExposed>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__HomePage</target>
        <target>lightning__RecordPage</target>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__AppPage,lightning__HomePage,lightning__RecordPage">
            <property name="portalTitle" type="String" label="Portal Title" default="Patient Appointment Portal" />
            <property name="portalSubtitle" type="String" label="Portal Subtitle" default="Sign in, choose a specialty, pick a nearby branch, and book with the right doctor." />
            <property name="singleHospitalMode" type="Boolean" label="Single Hospital Mode" default="true" />
            <property name="defaultHospitalId" type="String" label="Default Hospital Id" />
            <property name="defaultHospitalName" type="String" label="Default Hospital Name" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
